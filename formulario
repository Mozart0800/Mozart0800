<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Página de Cadastro</title>
</head>
<body>

    <header>
        <h1>Formulário de Cadastro</h1>
        <h4>Preencha todos os campos abaixo para concluir sua inscrição.</h4>
    </header>
    <hr>

    <main>
        <form action="#">
            
            <section>
                <label for="nome_completo">Nome Completo:</label>
                <input type="text" name="nome_completo" required>
            </section>
            <br>

            <section>
                <label for="email_contato">E-mail:</label>
                <input type="email" name="email_contato" required>
            </section>
            <br>

            <section>
                <label for="senha_usuario">Senha:</label>
                <input type="password" name="senha_usuario" required>
            </section>
            <br>

            <section>
                <label for="idade_usuario">Idade:</label>
                <input type="number" name="idade_usuario" min="0">
            </section>
            <br>

            <section>
                <label for="data_registro">Data de Nascimento:</label>
                <input type="date" name="data_registro">
            </section>
            <br>

            <section>
                <label for="escolaridade">Nível de Escolaridade:</label>
                <select name="escolaridade">
                    <option value="fundamental">Ensino Fundamental</option>
                    <option value="medio">Ensino Médio</option>
                    <option value="superior">Ensino Superior</option>
                </select>
            </section>
            <br>

            <section>
                <label>Turno de preferência:</label><br>
                <input type="radio" name="turno" value="manha">
                <label for="manha">Manhã</label>
                <input type="radio" name="turno" value="noite">
                <label for="noite">Noite</label>
            </section>
            <br>

            <section>
                <input type="checkbox" name="notificacoes">
                <label for="notificacoes">Desejo receber notificações por e-mail</label>
            </section>
            <br>

            <section>
                <label for="biografia">Breve biografia:</label><br>
                <textarea name="biografia" rows="4" cols="30"></textarea>
            </section>
            <br>

            <button type="submit">Enviar Dados</button>

        </form>
    </main>
    <hr>

    <footer>
        <p><a href="https://github.com/Mozart0800" target="_blank">GitHub</a></p>
    </footer>

</body>
</html>
